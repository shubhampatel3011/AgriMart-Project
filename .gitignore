# =========================
# MERN Stack .gitignore
# =========================

# Dependencies
node_modules/
jspm_packages/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build folders
dist/
build/
coverage/

# Cache
.cache/
.parcel-cache/
.next/
.nuxt/
.vite/
.temp/

# OS generated files
.DS_Store
Thumbs.db

# IDE / Editor files
.vscode/
.idea/
*.swp
*.swo

# React frontend
frontend/node_modules/
frontend/build/
frontend/dist/

# Backend / Express
backend/node_modules/
backend/uploads/
backend/dist/

# MongoDB
*.mongodb
dump/

# Optional lock files
package-lock.json
yarn.lock
pnpm-lock.yaml

# TypeScript
*.tsbuildinfo

# Testing
coverage/
.nyc_output/

# Misc
*.zip
*.tar.gz
*.rar

# Firebase
.firebase/

# Netlify
.netlify/

# Vercel
.vercel/

# Docker
docker-compose.override.yml

# PM2
.pm2/

# Mac system files
.AppleDouble
.LSOverride